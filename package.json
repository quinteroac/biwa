{
  "name": "visual-novel-experiment",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./framework/index.ts",
    "./engine": "./framework/engine.ts",
    "./react": "./framework/react.ts",
    "./plugins": "./framework/plugins.ts",
    "./types": "./framework/types.ts",
    "./manager": "./manager/index.ts"
  },
  "scripts": {
    "dev": "bun manager/cli.ts dev",
    "build": "bun manager/cli.ts build",
    "new": "bun manager/cli.ts new",
    "list": "bun manager/cli.ts list",
    "doctor": "bun manager/cli.ts doctor",
    "studio": "bun studio/dev.ts",
    "studio:api": "bun studio/server/index.ts",
    "studio:app": "vite --config studio/app/vite.config.ts",
    "studio:build": "vite build --config studio/app/vite.config.ts",
    "test": "bun test framework manager studio/server",
    "coverage": "bun test --coverage framework manager studio/server",
    "typecheck": "tsc",
    "check": "bun run test && bun run typecheck",
    "build:demo": "bun manager/cli.ts build smoke-fixture",
    "e2e": "playwright test",
    "verify": "bun run check && bun manager/cli.ts doctor smoke-fixture && bun run build:demo && bun run e2e"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.5",
    "@monaco-editor/react": "^4.7.0",
    "@tanstack/react-query": "^5.100.5",
    "@tanstack/react-router": "^1.168.25",
    "@vitejs/plugin-react": "^6.0.1",
    "elysia": "^1.4.28",
    "inkjs": "^2.3.0",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "vite": "^8.0.10",
    "yoga-layout": "^3.2.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "bun-types": "latest",
    "js-yaml": "^4.1.0",
    "typescript": "^5.8.0"
  }
}
