{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "game.config.js",
  "description": "JSON Schema for the game's configuration (game.config.js)",
  "type": "object",
  "required": ["id", "title", "version", "story"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "Unique identifier. Only [a-z0-9-]. Used as a namespace in localStorage"
    },
    "title": { "type": "string" },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(?:-[A-Za-z0-9.-]+)?$",
      "description": "Semver. New saves store this value and major-version mismatches are rejected when save metadata is present"
    },
    "description": { "type": "string" },
    "cover": { "type": "string" },
    "story": {
      "type": "object",
      "required": ["defaultLocale", "locales"],
      "properties": {
        "defaultLocale": { "type": "string" },
        "locales": {
          "type": "object",
          "description": "Map of locale → .ink file path",
          "additionalProperties": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "data": {
      "type": "object",
      "properties": {
        "characters": { "type": "string" },
        "scenes": { "type": "string" },
        "audio": { "type": "string" },
        "minigames": { "type": "string" },
        "gallery": { "type": "string" },
        "music": { "type": "string" },
        "replay": { "type": "string" }
      },
      "additionalProperties": { "type": "string" }
    },
    "minigames": {
      "type": "object",
      "additionalProperties": { "description": "Entry for lazy-loading a minigame (path or function)", "anyOf": [{ "type": "string" }, { "type": "function" }, { "type": "object" }, { "type": "null" }] }
    },
    "plugins": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "version", "type", "capabilities"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
          "name": { "type": "string", "minLength": 1 },
          "version": { "type": "string", "minLength": 1 },
          "type": { "type": "string", "enum": ["plugin"] },
          "entry": { "type": "string" },
          "capabilities": {
            "type": "array",
            "items": { "type": "string", "enum": ["renderer", "stage", "overlay", "engine-event", "asset-loader"] }
          },
          "renderers": {
            "type": "object",
            "properties": {
              "background": { "type": "array", "items": { "type": "string", "minLength": 1 } },
              "character": { "type": "array", "items": { "type": "string", "minLength": 1 } },
              "transition": { "type": "array", "items": { "type": "string", "minLength": 1 } },
              "overlay": { "type": "array", "items": { "type": "string", "minLength": 1 } },
              "extras": { "type": "array", "items": { "type": "string", "minLength": 1 } }
            },
            "additionalProperties": false
          },
          "compatibility": {
            "type": "object",
            "properties": {
              "framework": { "type": "string" }
            },
            "additionalProperties": false
          },
          "module": { "description": "Runtime-only plugin module object", "anyOf": [{ "type": "object" }, { "type": "null" }] },
          "loader": { "description": "Runtime-only plugin loader function", "anyOf": [{ "type": "function" }, { "type": "object" }, { "type": "null" }] }
        },
        "additionalProperties": false
      }
    },
    "theme": {
      "type": "object",
      "properties": {
        "font": { "type": "string" },
        "dialogBg": { "type": "string" },
        "accent": { "type": "string" },
        "cssVars": { "type": "object", "additionalProperties": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "saves": {
      "type": "object",
      "properties": {
        "slots": { "type": "integer", "minimum": 1 },
        "autoSave": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "diagnostics": {
      "type": "object",
      "properties": {
        "suppress": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["reason"],
            "properties": {
              "code": { "type": "string" },
              "path": { "type": "string" },
              "message": { "type": "string" },
              "reason": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "endScreen": {
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "message": { "type": "string" }
      },
      "additionalProperties": false
    },
    "distribution": {
      "type": "object",
      "properties": {
        "mode": { "type": "string", "enum": ["standalone", "portal", "static", "embedded"] },
        "basePath": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
